# Required: protects /v1/* endpoints.
API_TOKEN=change-me

# Provider credentials (only set the ones you use; others are skipped).
OPENAI_ADMIN_KEY=
ANTHROPIC_ADMIN_KEY=
GEMINI_API_KEY=
ZAI_API_KEY=

# Optional tuning.
PORT=3000
CACHE_TTL_SECONDS=300
EXEC_TIMEOUT_MS=30000
CODEXBAR_PROVIDERS=codex,claude,gemini,z.ai
